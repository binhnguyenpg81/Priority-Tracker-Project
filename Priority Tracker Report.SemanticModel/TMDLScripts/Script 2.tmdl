			measure 'KPI Card | Value Target Reference' = ```
					
					VAR _Metric_Variance = [Shipment # Value Target Achievement]
					VAR _Metric_Growth = [Shipment # Value Target % Achievement]
					
					VAR _Format_Variance = "▲ +#.00; ▼ -#.00;0"
					VAR _Format_Growth = "+0.0%; -0.0%;0%"
					
					VAR _Formated_Variance = FORMAT( _Metric_Variance , _Format_Variance)
					VAR _Formated_Growth = FORMAT( _Metric_Growth , _Format_Growth)
					
					VAR _Divider = " | "
					VAR _Space   = " "
					
					VAR _result = 
					SWITCH(
					    TRUE(),
					    _Metric_Variance = 0 , "-",
					    _Space & _Formated_Variance & _Divider & _Formated_Growth)
