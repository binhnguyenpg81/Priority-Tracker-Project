			column key_qdgp =
					
					VAR _local_channel = LOOKUPVALUE( dim_store_vn_do[region_localchannel] , dim_store_vn_do[store_id], vn_indirect_shipment_fct[store_key] )
					VAR _year_month = RELATED( vn_calendar[yearmonth])
					VAR _fpd_id = LOOKUPVALUE( dim_product[fpc_id] , dim_product[prod_key], vn_indirect_shipment_fct[prod_key])
					RETURN
					_year_month&"_"&_local_channel&"_"&_fpd_id
				lineageTag: b011273b-f9b4-468c-800f-cdb91762fa7f
				summarizeBy: none

				annotation SummarizationSetBy = Automatic

			column key_qdgp_group =
					
					VAR _local_channel = LOOKUPVALUE( dim_store_vn_do[region_localchannel] , dim_store_vn_do[store_id], vn_indirect_shipment_fct[store_key] )
					VAR _year_month = RELATED( vn_calendar[yearmonth])
					VAR _group = RELATED(fct_qdgp[GroupName])
					RETURN
					_year_month&"_"&_local_channel&"_"&_group
				lineageTag: 3702cf3f-98ea-4971-9290-639489f94228
				summarizeBy: none

				annotation SummarizationSetBy = Automatic

			column qdgp_hit = ```
					
					VAR _QDGP_Sum_Unit = 
					CALCULATE(
					    SUM(vn_indirect_shipment_fct[Indirect_Unit_Shipments]),
					    ALLEXCEPT(vn_indirect_shipment_fct,vn_indirect_shipment_fct[store_key],vn_indirect_shipment_fct[key_qdgp_group]))
					VAR _QDGP_MOQ = 
					CALCULATE(
					    SELECTEDVALUE(fct_qdgp[MOQ (IT)]),
					    ALLEXCEPT(fct_qdgp,fct_qdgp[QDGP_Group_Key],fct_qdgp[GroupName],fct_qdgp[MOQ (IT)]))    
					RETURN 
					IF(ISBLANK(_QDGP_MOQ),BLANK(),  
					      IF(ROUND(_QDGP_Sum_Unit,0) >=VALUE(_QDGP_MOQ),1,0))
					```
				formatString: 0
