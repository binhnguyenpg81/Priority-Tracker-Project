		table dim_brand
			lineageTag: f65ccd4d-824d-4e8a-b987-6f5116b99696

			column brand
				lineageTag: d2936926-3eff-4e35-a640-d2ac6c102770
				summarizeBy: none
				isNameInferred
				sourceColumn: sos_sod_fct_hsm[brand]

				annotation SummarizationSetBy = Automatic

			partition dim_brand = calculated
				mode: import
				source = ```
						
						VAR _gr_1 = 
						SUMMARIZE(
						    sos_sod_fct_hsm,
						    sos_sod_fct_hsm[brand]
						)
						VAR _gr_2 = 
						SUMMARIZE(
						    FILTER(dim_product, NOT ISBLANK(dim_product[brand])),
						    dim_product[brand]
						)
						VAR _result = 
						DISTINCT(UNION(_gr_1,_gr_2))
						RETURN
						_result
						```

