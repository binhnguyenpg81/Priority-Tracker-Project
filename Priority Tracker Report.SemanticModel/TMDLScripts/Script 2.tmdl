			column sub_channel =
					
					SWITCH(
					    TRUE(),
					    vn_pos_monthly[data_provider_key] = "10000101724280", "Winmart",
					    vn_pos_monthly[data_provider_key] = "10000101759516", "Aeon",
					    vn_pos_monthly[data_provider_key] = "10000101759517", "Mega Market",
					    vn_pos_monthly[data_provider_key] = "10000101724279", "Coop",
					    vn_pos_monthly[data_provider_key] = "10000101759543", "Emart",
					    vn_pos_monthly[data_provider_key] = "10000101752637", "Bach Hoa Xanh",
					    vn_pos_monthly[data_provider_key] = "10000101759522", "Lotte",
					    vn_pos_monthly[data_provider_key] = "10000101759579", "Guardian",
					    "Others"
					)
