						    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns",{{"Custom", "sales_value"}, {"store_key", "store_id"}, {"sales_quantity", "sales_qty"}, {"inventory_value", "closing_value"}, {"inventory_quantity", "closing_qty"}}),
						    #"Changed Type2" = Table.TransformColumnTypes(#"Renamed Columns",{{"sales_value", type number}}),
						    #"Added Custom1" = Table.AddColumn(#"Changed Type2", "key_prod_prov", each [prod_key]&[data_provider_key]),
