				lineageTag: b6ccebc2-1224-4779-89e9-29c7794e4805

			measure 'Sellout # Value RTDC Target Achievement L12M WS' =
					
					VAR _MaxDate = MAX(vn_calendar[date])
					VAR _L12M = EDATE(_MaxDate,-12)
					VAR _Shipment =
					CALCULATE(
					    [Sellout # Value RTDC Target Achievement WS],
					    REMOVEFILTERS( vn_calendar),
					    vn_calendar[date] >= _L12M &&
					    vn_calendar[date] <= _MaxDate,
					    USERELATIONSHIP( vn_calendar[date], vn_calendar_filter[date])
					)
					RETURN
					_Shipment
				formatString: 0.00%;-0.00%;0.00%
				displayFolder: 02 Sellout
				lineageTag: 41d1f29e-0ea1-43eb-a103-71d27f0f6c44

