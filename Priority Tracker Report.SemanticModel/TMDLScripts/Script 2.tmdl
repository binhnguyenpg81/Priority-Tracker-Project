		table '00 Measure'
			lineageTag: d7ec3265-d376-40a3-996a-4e51426a3f7a

			measure 'Shipment # Value' = (SUM(vn_direct_shipment_fct[shipment_giv_value]) * 1.08) / 10^9
				displayFolder: 01 Shipment
				lineageTag: 08a5eef3-2411-4322-90da-fb2028ce861b

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Shipment # Value FYTD PY' =
					
					CALCULATE(
					    [Shipment # Value FYTD],
					    SAMEPERIODLASTYEAR( vn_calendar[date] )
					)
				displayFolder: 01 Shipment
				lineageTag: 5089cf54-472d-4e91-b2c5-7b293baa7adc

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Shipment # Value FYTD' = ```
					
					CALCULATE(
					    [Shipment # Value],
					    DATESYTD( vn_calendar[date] , "6-30") 
					)
					```
				displayFolder: 01 Shipment
				lineageTag: 50289132-6b32-40ae-934a-f11858408ddb

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Shipment # Value JAS' = ```
					
					VAR _JAS_Value = 
					CALCULATE(
					    [Shipment # Value],
					    FILTER(
					        ALL(vn_calendar),
					        vn_calendar[year_fiscal] IN VALUES(vn_calendar[year_fiscal])  && 
					        vn_calendar[month] IN {"07","08","09"}
					    ))
					VAR _JAS_Month_Num =
					CALCULATE(
					    DISTINCTCOUNT(vn_calendar[year_fiscal]),
					    FILTER(
					        ALL(vn_calendar),
					        vn_calendar[year_fiscal] IN VALUES(vn_calendar[year_fiscal]) &&
					        vn_calendar[month] IN {"07","08","09"}
					    )
					)
					RETURN
					DIVIDE( _JAS_Value , _JAS_Month_Num * 3)
					```
				formatString: #,0
				displayFolder: 01 Shipment
				lineageTag: 821f2636-b856-4c36-ae78-c75e630a3440

			measure 'Shipment # Value FYTD IYA' =
					
					DIVIDE([Shipment # Value FYTD],[Shipment # Value FYTD PY]) * 100
				displayFolder: 01 Shipment
				lineageTag: 0e19b341-d45c-4b15-90c8-35181f5f1ebc

				annotation PBI_FormatHint = {"isGeneralNumber":true}

