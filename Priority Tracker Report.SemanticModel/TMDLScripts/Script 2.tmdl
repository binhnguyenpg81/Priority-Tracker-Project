			column store_code = ```
					
					VAR _key = vn_pos_monthly[store_id] & vn_pos_monthly[data_provider_key]
					VAR _val =
					    LOOKUPVALUE(
					        vn_pos_store_dim_vw[site_id],
					        vn_pos_store_dim_vw[store_key],
					        _key
					    )
					VAR _val_MM = 
					    LOOKUPVALUE(
					        dim_store_sfdc[store_code],
					        dim_store_sfdc[pos_store_code],
					        vn_pos_monthly[store_id]
					    )
					VAR _num = RIGHT( _val, LEN( _val ) - 4 )
					RETURN
					SWITCH(
					    TRUE( ),
					    vn_pos_monthly[data_provider_key] = "10000101724280",
					        "WCM_" & _num,
					    vn_pos_monthly[data_provider_key] = "10000101752637",
					        "BHX_" & _num,
					    vn_pos_monthly[data_provider_key] = "10000101759516",
					        "AEON_" & RIGHT(_val,4),
					    vn_pos_monthly[data_provider_key] = "10000101759517",
					        _val_MM,
					    vn_pos_monthly[data_provider_key] = "10000101759543",
					        _num,
					    vn_pos_monthly[data_provider_key] = "10000101759522",
					        _num,
					    IF(ISBLANK(_num), BLANK(), _num)
					)
					```
				lineageTag: 51ca8819-83eb-4fb3-945d-4a4eb7183c42
				summarizeBy: none

				annotation SummarizationSetBy = Automatic

			column KEY = ```
					
					VAR _key = vn_pos_monthly[store_id] & vn_pos_monthly[data_provider_key]
					RETURN 
					LOOKUPVALUE(
					        vn_pos_store_dim_vw[site_id],
					        vn_pos_store_dim_vw[store_key],
					        _key
					    )
