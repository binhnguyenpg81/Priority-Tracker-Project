			measure 'Card # Shipment Period | Value Share' = ```
					
					VAR _Num_Month = DISTINCTCOUNT(vn_calendar[yearmonth])
					VAR _All_Month =
					    CALCULATE(
					        DISTINCTCOUNT(vn_calendar[yearmonth]),
					        ALL(vn_calendar)
					    )
					VAR _Text = 
					SWITCH(
					    TRUE(),
					    _Num_Month = _All_Month, "Bil | All",
					    _Num_Month = 1,  FORMAT(MAX(vn_calendar[date]), "MMM'YY"),
					    _Num_Month > 1,  FORMAT( MIN(vn_calendar[date]), "MMM'YY" ) & "-" & FORMAT( MAX(vn_calendar[date]), "MMM'YY" )
					)
					RETURN
					_Text 
					```
				displayFolder: 99 Other
				lineageTag: 31a757a6-64f5-46a3-bb8f-ca324eef0522

			measure 'Value Share # Value L12M' =
					
					VAR _MaxDate = MAX(vn_calendar[date])
					VAR _L12M = EDATE(_MaxDate,-12)
					VAR _Shipment =
					CALCULATE(
					    [Value Share # Value],
					    REMOVEFILTERS( vn_calendar),
					    vn_calendar[date] >= _L12M &&
					    vn_calendar[date] <= _MaxDate,
					    USERELATIONSHIP( vn_calendar[date], vn_calendar_filter[date])
					)
					RETURN
					_Shipment
