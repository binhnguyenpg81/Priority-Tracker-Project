				    #"Removed Other Columns" = Table.SelectColumns(Query_,{"36 Customer.Corp Distributor Branch ID", "20 Time.Month (Real)", "61 Store.Route Identifier", "61 Store.Source Store ID", "Indirect NIV Shipments", "IGPGroup_Offtake", "Product Group"})
				in
