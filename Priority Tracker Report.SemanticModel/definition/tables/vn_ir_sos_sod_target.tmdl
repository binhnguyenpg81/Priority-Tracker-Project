	partition vn_ir_sos_sod_target = calculated
		mode: import
		source = ```
				
				VAR _hsm =
				    ADDCOLUMNS(
				        SUMMARIZE(
				            sos_sod_fct_hsm,
				            sos_sod_fct_hsm[year_month],
				            sos_sod_fct_hsm[store_id],
				            sos_sod_fct_hsm[type],
				            sos_sod_fct_hsm[category_total],
				            "linear", SUM(sos_sod_fct_hsm[linear]),
				            "visit_in_month", DISTINCTCOUNT(sos_sod_fct_hsm[visit_id])
				        ),
				        "avg total", [linear] / [visit_in_month]
				    )
				
				VAR _smallbox =
				    ADDCOLUMNS(
				        SUMMARIZE(
				            sos_sod_fct_sb,
				            sos_sod_fct_sb[year_month],
				            sos_sod_fct_sb[store_id],
				            sos_sod_fct_sb[type_total],
				            sos_sod_fct_sb[category_total],
				            "linear", SUM(sos_sod_fct_sb[actual]),
				            "visit_in_month", DISTINCTCOUNT(sos_sod_fct_sb[visit_id])
				        ),
				        "avg total", [linear] / [visit_in_month]
				    )
				
				// VAR _result =
				//     UNION(
				//         SELECTCOLUMNS(
				//             _hsm,
				//             "yearmonth", [yearmonth],
				//             "store_id", [internal_code],
				//             "type", [type],
				//             "category_brand", [category_brand],
				//             "linear", [linear],
				//             "visit_in_month", [visit_in_month],
				//             "avg total", [avg total]
				//         ),
				
				//         SELECTCOLUMNS(
				//             _smallbox,
				//             "yearmonth", [year_month],
				//             "store_id", [store_id],
				//             "type", [type],
				//             "category_brand", [shipment_category_brand],
				//             "linear", [linear],
				//             "visit_in_month", [visit_in_month],
				//             "avg total", [avg total]
				//         )
				//     )
				VAR _result = 
				UNION(_hsm,_smallbox)
				RETURN
				_smallbox
				```

	annotation PBI_Id = eaa85afb951442958a85126ede183702

