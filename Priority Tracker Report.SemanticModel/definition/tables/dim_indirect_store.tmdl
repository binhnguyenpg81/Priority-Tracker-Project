	column last_store_id = ```
			
			VAR _max = 
			CALCULATE(
			    MAX(dim_indirect_store_hist[begin_date]),
			    FILTER(
			        dim_indirect_store_hist,
			        dim_indirect_store[pr_key] = dim_indirect_store_hist[store_id]
			    ))
			VAR _channel = 
			CALCULATE(
			    MAX(dim_indirect_store_hist[sub_channel]),
			    FILTER(
			        dim_indirect_store_hist,
			        dim_indirect_store[pr_key] = dim_indirect_store_hist[store_id] && dim_indirect_store_hist[begin_date] = _max
			    ))
			VAR _compare = 
			IF(dim_indirect_store[sub_channel] = _channel, "Same","Different")
			RETURN
			_compare
			```
		lineageTag: b03c47c4-cd45-4cdf-a4c3-ab3199960a5d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

