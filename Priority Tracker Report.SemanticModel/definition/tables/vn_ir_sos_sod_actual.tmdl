	column year_month
		lineageTag: 44369bab-2a67-4999-8051-a7c19b5b898b
		isNameInferred
		sourceColumn: sos_sod_fct_hsm[year_month]

	partition vn_ir_sos_sod_actual = calculated
		mode: import
		source = ```
				
				VAR _table = 
				FILTER(
				    'sos_sod_fct_hsm',
				    'sos_sod_fct_hsm'[own] = 1
				)
				VAR _hsm = 
				ADDCOLUMNS(
				    SUMMARIZE(
				        _table,
				        sos_sod_fct_hsm[year_month],
				        sos_sod_fct_hsm[store_id],
				        sos_sod_fct_hsm[type],
				        sos_sod_fct_hsm[category],
				        sos_sod_fct_hsm[brand],
				        "linear", SUM(sos_sod_fct_hsm[linear]),
				        "visit_in_month", DISTINCTCOUNT(sos_sod_fct_hsm[visit_id])
				    ),
				    "avg total", [linear]/[visit_in_month]
				)
				VAR _smallbox = 
				    SUMMARIZE(
				        FILTER(
				            sos_sod_fct_sb,
				            sos_sod_fct_sb[type] = "SOS" || sos_sod_fct_sb[type] = "SOD"),
				        sos_sod_fct_sb[year_month],
				        sos_sod_fct_sb[store_id],
				        sos_sod_fct_sb[type],
				        sos_sod_fct_sb[category],
				        sos_sod_fct_sb[brand],
				        "linear", SUM(sos_sod_fct_sb[actual]),
				        "visit_in_month", SUM(sos_sod_fct_sb[actual]),
				        "avg total", AVERAGE(sos_sod_fct_sb[actual])
				    )
				VAR _result = 
				UNION(_hsm,_smallbox)
				RETURN
				_result
				```

	annotation PBI_Id = 1369e0899fce41d5abb177a8baac5757

