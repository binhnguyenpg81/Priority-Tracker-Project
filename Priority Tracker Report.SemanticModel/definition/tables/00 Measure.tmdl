			    || CONTAINSSTRING ( vn_hpt_displaycheck_visitmonth[display_program], "GOLD" )
			    || CONTAINSSTRING ( vn_hpt_displaycheck_visitmonth[display_program], "PLATINUM" )
			)
		formatString: 0.00%;-0.00%;0.00%
