	measure 'Shipment # Value L12M' =
			
			VAR _MaxDate = MAX(vn_calendar[date])
			VAR _L12M = EDATE(_MaxDate,-12)
			VAR _Shipment =
			CALCULATE(
			    [Shipment # Value],
			    REMOVEFILTERS( vn_calendar),
			    vn_calendar[date] >= _L12M &&
			    vn_calendar[date] <= _MaxDate,
			    USERELATIONSHIP( vn_calendar[date], vn_calendar_filter[date])
			)
			RETURN
			_Shipment
		displayFolder: 01 Shipment
		lineageTag: 047e0b56-02b0-4214-8794-f95f99931824

		annotation PBI_FormatHint = {"isGeneralNumber":true}

