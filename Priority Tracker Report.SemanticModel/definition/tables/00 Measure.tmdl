	measure 'DGP # Value L12M' =
			
			VAR _MaxDate = MAX(vn_calendar[date])
			VAR _L12M = EDATE(_MaxDate,-12)
			VAR _Shipment =
			CALCULATE(
			    [DGP # Value],
			    REMOVEFILTERS( vn_calendar),
			    vn_calendar[date] >= _L12M &&
			    vn_calendar[date] <= _MaxDate,
			    USERELATIONSHIP( vn_calendar[date], vn_calendar_filter[date])
			)
			RETURN
			_Shipment
		formatString: #,0
		displayFolder: 03 DGP
		lineageTag: a18d2ed6-b1ef-4df5-b31a-f4078b5bfa92

