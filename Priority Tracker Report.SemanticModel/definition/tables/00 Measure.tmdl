	measure 'Bill # No.Bill' =
			
			CALCULATE(
			    DISTINCTCOUNT(vn_indirect_shipment_fct[bill_id]),
			    vn_indirect_shipment_fct[indirect_giv_shipment] > 0
			)
		formatString: #,0
		displayFolder: 10 Bill
		lineageTag: b2b998c8-36c3-46e6-b9b7-362d08a57e15

	measure 'Bill # Avg. No. Bill/Day' = ```
			
			VAR WorkingDays = 
			COUNTROWS(
			    FILTER(
			        vn_calendar,
			        WEEKDAY(vn_calendar[Date], 2) <= 6
			    )
			)
			VAR Seller = DISTINCTCOUNT( dim_indirect_store[seller_id_key])
			VAR Result = 
			DIVIDE(
			    [Bill # No.Bill],
			    WorkingDays * Seller
			)
			RETURN
			Result
			```
		formatString: 0
		displayFolder: 10 Bill
		lineageTag: f14bfff9-b4f2-499e-9b2d-e293237d2494

