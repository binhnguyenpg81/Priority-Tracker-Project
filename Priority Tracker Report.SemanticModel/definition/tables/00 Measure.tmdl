	measure 'Shipment # Value JAS' = ```
			
			VAR _JAS_Value = 
			CALCULATE(
			    [Shipment # Value],
			    FILTER(
			        ALL(vn_calendar),
			        vn_calendar[year_fiscal] IN VALUES(vn_calendar[year_fiscal])  && 
			        vn_calendar[month] IN {"07","08","09"}
			    ))
			VAR _JAS_Month_Num =
			CALCULATE(
			    DISTINCTCOUNT(vn_calendar[year_fiscal]),
			    FILTER(
			        ALL(vn_calendar),
			        vn_calendar[year_fiscal] IN VALUES(vn_calendar[year_fiscal]) &&
			        vn_calendar[month] IN {"07","08","09"}
			    )
			)
			RETURN
			DIVIDE( _JAS_Value , _JAS_Month_Num * 3)
