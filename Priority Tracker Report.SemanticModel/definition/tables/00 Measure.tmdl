	measure 'Time Elapsed' =
			
			VAR SelectedDate = MAX( vn_calendar[date] )
			VAR TodayDate = TODAY( )
			
			-- Check if selected month is before current month
			VAR IsPastMonth =
			    YEAR( SelectedDate ) < YEAR( TodayDate )
			        || ( YEAR( SelectedDate ) = YEAR( TodayDate )
			        && MONTH( SelectedDate ) < MONTH( TodayDate ) )
			
			-- Use TODAY() if current month is selected; else use selected date
			VAR EffectiveMaxDate =
			    IF( IsPastMonth, SelectedDate, TodayDate )
			
			-- Start of selected month
			VAR _StartOfMonth =
			    DATE( YEAR( SelectedDate ), MONTH( SelectedDate ), 1 )
			
			-- Max day = number of working days from start of month to effective max date
			VAR Max_day =
			    CALCULATE(
			        COUNTROWS( vn_calendar ),
			        vn_calendar[date] <= EffectiveMaxDate,
			        vn_calendar[date] >= _StartOfMonth
			    )
			
			-- Total calendar days in selected month
			VAR Total_working_days = DAY( EOMONTH( SelectedDate, 0 ) )
			
			-- Remove custom non-working days from numerator
			VAR numerator =
			    Max_day
			        - CALCULATE(
			            COUNT( vn_workday[workday] ),
			            FILTER(
			                vn_workday,
			                vn_workday[count of working days] = 0
			                    && vn_workday[date] <= EffectiveMaxDate
			            )
			        )
			
			-- Remove Sundays + custom days from denominator
			VAR denominator =
			    Total_working_days
			        - ( [SundayCountInCurrentMonth]
			        + CALCULATE(
			            COUNT( vn_workday[workday] ),
			            FILTER(
			                vn_workday,
			                vn_workday[Denominator] = 0
			                    && vn_workday[date] <= SelectedDate
			            )
			        ) )
			RETURN
			    IF(
			        IsPastMonth,
			        1,  -- return 100%
			        DIVIDE( numerator - 1, denominator, 0 )
			    )
		displayFolder: 09 GoldenStore
		lineageTag: 915ab21d-dfa7-4d0f-af37-b35321ce63d4

	measure SundayCountInCurrentMonth =
			
			VAR TodayDate = max(vn_calendar[date])
			VAR StartOfMonthdate = DATE(YEAR(TodayDate), MONTH(TodayDate), 1)
			VAR EndOfMonthdate = EOMONTH(TodayDate, 0)
			VAR DaysInMonth = DATEDIFF(StartOfMonthdate, EndOfMonthdate, DAY) + 1
			VAR AllDates =
			    ADDCOLUMNS(
			        GENERATESERIES(0, DaysInMonth - 1, 1),
			        "DateValue", StartOfMonthdate + [Value]
			    )
			RETURN
			COUNTROWS(
			    FILTER(
			        AllDates,
			        WEEKDAY([DateValue], 2) = 7  -- Sunday (week starts on Monday)
			    )
			)
		formatString: 0
		displayFolder: 09 GoldenStore
		lineageTag: 6c35a6e0-7417-4b12-bc4b-5cddc1f967f4

	measure 'LP # Visibility' =
			
