	measure 'Card # Shipment Period | Shipment Value' = ```
			
			VAR _Num_Month = DISTINCTCOUNT(vn_calendar[yearmonth])
			VAR _All_Month =
			    CALCULATE(
			        DISTINCTCOUNT(vn_calendar[yearmonth]),
			        ALL(vn_calendar)
			    )
			VAR _Text = 
			SWITCH(
			    TRUE(),
			    _Num_Month = _All_Month, "Bil | All",
			    _Num_Month = 1, "Bil | " & FORMAT(MAX(vn_calendar[date]), "MMM'YY"),
			    _Num_Month > 1, "Bil | " & FORMAT( MIN(vn_calendar[date]), "MMM'YY" ) & "-" & FORMAT( MAX(vn_calendar[date]), "MMM'YY" )
			)
			RETURN
			_Text 
			```
		displayFolder: 99 Other
		lineageTag: c6074d70-6ba0-4867-aa67-f54919c6c368

	measure 'KPI Card | Value Target Reference' = ```
			
			VAR _Metric_Variance = [Shipment # Value Target Achievement]
			VAR _Metric_Growth = [Shipment # Value Target % Achievement]
			
			VAR _Format_Variance = "▲ +#.00; ▼ -#.00;0"
			VAR _Format_Growth = "+0.0%; -0.0%;0%"
			
			VAR _Formated_Variance = FORMAT( _Metric_Variance , _Format_Variance)
			VAR _Formated_Growth = FORMAT( _Metric_Growth , _Format_Growth)
			
			VAR _Divider = " | "
			VAR _Space   = " "
			
			VAR _result = 
			SWITCH(
			    TRUE(),
			    _Metric_Variance = 0 , "-",
			    _Space & _Formated_Variance & _Divider & _Formated_Growth)
			RETURN 
			_result
			```
		displayFolder: 01 Shipment
		lineageTag: e1e4ef84-a301-423c-abff-c9a508ceae8a

