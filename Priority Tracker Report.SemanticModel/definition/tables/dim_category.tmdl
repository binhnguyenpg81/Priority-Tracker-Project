	partition dim_category = calculated
		mode: import
		source = ```
				
				VAR _gr_1 = 
				SUMMARIZE(
				    dim_product,
				    dim_product[category]
				)
				VAR _gr_2 = 
				SUMMARIZE( share_value_fct_total, share_value_fct_total[category])
				RETURN
				DISTINCT(UNION(_gr_1,_gr_2))
				```

